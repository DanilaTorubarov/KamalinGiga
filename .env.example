# ──────────────────────────────────────────────────────────────────────────────
# Razvlekis — environment variables
# Copy this file to .env and fill in your keys, then:
#   docker compose up -d --build
# ──────────────────────────────────────────────────────────────────────────────

# Google Maps Platform API key
# Required for: address geocoding + nearby-place search
#
# How to get:
#   1. Go to https://console.cloud.google.com/apis/credentials
#   2. Create a new API key (or use an existing one)
#   3. Enable the following APIs on the key:
#        • Geocoding API
#        • Places API
#
GOOGLE_MAPS_KEY=your-google-maps-key-here

# Google AI (Gemini) API key
# Required for: the in-app chat assistant
# Optional — the chat will show a friendly notice if this key is absent.
#
# How to get:
#   1. Go to https://aistudio.google.com/app/apikey
#   2. Click "Create API key"
#
GOOGLE_AI_KEY=your-google-ai-key-here
